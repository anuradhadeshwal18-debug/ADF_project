{
	"name": "factbookings",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "ls_sqldatalake",
						"type": "LinkedServiceReference"
					},
					"name": "FactBookings"
				},
				{
					"linkedService": {
						"referenceName": "ls_sqldatalake",
						"type": "LinkedServiceReference"
					},
					"name": "DimAirline"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "ls_sqldatalake",
						"type": "LinkedServiceReference"
					},
					"name": "gold"
				}
			],
			"transformations": [
				{
					"name": "joinFactDim"
				},
				{
					"name": "aggregateRevenue"
				},
				{
					"name": "Rank"
				},
				{
					"name": "filterTop5"
				},
				{
					"name": "alterRow"
				},
				{
					"name": "selectcols"
				}
			],
			"scriptLines": [
				"source(output(",
				"          booking_id as integer,",
				"          passenger_id as integer,",
				"          flight_id as integer,",
				"          airline_id as integer,",
				"          origin_airport_id as integer,",
				"          destination_airport_id as integer,",
				"          booking_date as date,",
				"          ticket_cost as integer,",
				"          flight_duration_mins as integer,",
				"          checkin_status as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'delta',",
				"     fileSystem: 'silver',",
				"     folderPath: 'FactBookings') ~> FactBookings",
				"source(output(",
				"          airport_id as short,",
				"          airport_name as string,",
				"          city as string,",
				"          country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'delta',",
				"     fileSystem: 'silver',",
				"     folderPath: 'git') ~> DimAirline",
				"FactBookings, DimAirline join(airline_id == airport_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinFactDim",
				"selectcols aggregate(groupBy(airline_id),",
				"     TotalTicketCost = sum(ticket_cost)) ~> aggregateRevenue",
				"aggregateRevenue window(desc(TotalTicketCost, true),",
				"     Top = denseRank()) ~> Rank",
				"Rank filter(Top<=5) ~> filterTop5",
				"filterTop5 alterRow(insertIf(1==1)) ~> alterRow",
				"joinFactDim select(mapColumn(",
				"          booking_id,",
				"          passenger_id,",
				"          flight_id,",
				"          airline_id,",
				"          origin_airport_id,",
				"          destination_airport_id,",
				"          booking_date,",
				"          ticket_cost,",
				"          flight_duration_mins,",
				"          checkin_status,",
				"          airport_name,",
				"          city,",
				"          country",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectcols",
				"alterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: 'gold',",
				"     folderPath: 'BusinessView',",
				"     overwrite: true,",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: true,",
				"     updateable: false,",
				"     upsertable: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> gold"
			]
		}
	}
}